datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Memory {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  images Image[] @relation("MemoryImages")
}
model Image {
  id         Int      @id @default(autoincrement())
  url        String   @unique
  altText    String?
  uploadedAt DateTime @default(now())
  memoryId   Int?
  memory     Memory?  @relation("MemoryImages", fields: [memoryId], references: [id])
}

model Note {
  id        Int      @id @default(autoincrement())
  text      String
  author    String
  date      String
  createdAt DateTime @default(now())
}

model Dream {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TimelineEvent {
  id          Int      @id @default(autoincrement())
  date        String
  title       String
  description String
  icon        String
  createdAt   DateTime @default(now())
}
