datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Memory {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  images Image[] @relation("MemoryImages")

model Image {
  id         Int      @id @default(autoincrement())
  url        String   @unique
  altText    String?
  uploadedAt DateTime @default(now())
  memoryId   Int?
  memory     Memory?  @relation("MemoryImages", fields: [memoryId], references: [id])
}
